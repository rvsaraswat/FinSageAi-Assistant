# Zerodha Kite Connect API Credentials
# Get these from https://developers.kite.trade/
KITE_API_KEY=APIKEY
KITE_API_SECRET=APISECRET

# Access token (generated after login, expires daily)
# Leave empty - will be generated via login flow
KITE_ACCESS_TOKEN=

# App Secret - used to encrypt stored API credentials in the SQLite database
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')" | head -c 64
APP_SECRET=change-this-to-a-random-64-char-hex-string-before-running

# Admin Token - protects /api/accounts endpoints when accessed remotely
# If not set, account management is restricted to localhost only.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# CORS Origin - restrict which domains can call the API
# Comma-separated list for multiple origins, e.g.: https://app.yourdomain.com
# Leave empty to allow all origins (fine for localhost development)
CORS_ORIGIN=

# Ollama Configuration
OLLAMA_URL=http://localhost:11434

# MCP Configuration
# Set to '1' to use remote Kite MCP server instead of direct API
MCP_REMOTE=0
KITE_MCP_URL=https://mcp.kite.trade/mcp

# Server Port
PORT=15600
